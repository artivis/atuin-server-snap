#!/bin/sh
# get-db-password — print the generated bundled PostgreSQL password.
#
# Requires root (sudo). The password file is mode 600 and readable only
# by root, so non-root calls will be rejected regardless.
#
# Usage:
#   sudo snap run atuin-server.get-db-password
#
# The password is needed to connect to the bundled PostgreSQL manually:
#
#   PGPASSWORD=$(sudo snap run atuin-server.get-db-password) \
#     psql -h localhost -U atuin atuin
set -e

if [ "$(id -u)" -ne 0 ]; then
    echo "ERROR: this command must be run as root (use sudo)." >&2
    exit 1
fi

SECRET="${SNAP_COMMON}/postgres.secret"

if [ ! -f "${SECRET}" ]; then
    echo "ERROR: postgres.secret not found. Is the snap installed?" >&2
    exit 1
fi

# Source and print just the password value
# shellcheck source=/dev/null
. "${SECRET}"

if [ -z "${POSTGRES_PASSWORD}" ]; then
    echo "ERROR: POSTGRES_PASSWORD not set in ${SECRET}" >&2
    exit 1
fi

printf '%s\n' "${POSTGRES_PASSWORD}"
